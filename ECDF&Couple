    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "from scipy.stats import norm, shapiro, normaltest, skew, kurtosis, beta, multivariate_normal, rankdata\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.ensemble import IsolationForest\n",
    "from copulas.multivariate import GaussianMultivariate\n",
    "from matplotlib.colors import LogNorm\n",
    "\n",
    "warnings.filterwarnings(\"ignore\", category=UserWarning)\n",
    "\n",

    "INPUT_FILE = \"predicted_log_values.xlsx\"\n",
    "DOCK_COL = \"Docking\"\n",
    "TOX_COLS = [ \"women_oral_TDLo\"]\n",
    "OUTPUT_PREFIX = \"combined_results\"\n",
    "OUT_DIR = \"results\"\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "MULTIPLIER_ALPHA = 1.0\n",
    "SIGMOID_K = 0.1\n",
    "N_TOP = 20\n",
    "N_BOOT = 200\n",
    "CLIP_PROB = (1e-6, 1-1e-6)\n",
    "\n",
 
    "df = pd.read_excel(INPUT_FILE)\n",
    "out = df.copy()\n",
    "\n",
  
    "dock_vals = pd.to_numeric(out[DOCK_COL], errors='coerce').dropna()\n",
   
    "print(dock_vals.describe())\n",
    "\n",
  
    "stat_shapiro, p_shapiro = shapiro(dock_vals)\n",
    "stat_dagostino, p_dagostino = normaltest(dock_vals)\n",
    "print(f\"Shapiro-Wilk: W={stat_shapiro:.4f}, p={p_shapiro:.4g}\")\n",
    "print(f\"D'Agostino: K2={stat_dagostino:.4f}, p={p_dagostino:.4g}\")\n",
    "print(f\"(skew)={skew(dock_vals):.3f}, 峰度(kurtosis)={kurtosis(dock_vals):.3f}\")\n",
    "\n",

    "plt.figure(figsize=(6,4))\n",
    "count, bins, _ = plt.hist(dock_vals, bins=30, density=True, alpha=0.6, color='steelblue', edgecolor='k')\n",
    "mu, sigma = np.mean(dock_vals), np.std(dock_vals)\n",
    "x = np.linspace(min(bins), max(bins), 200)\n",
    "plt.plot(x, norm.pdf(x, mu, sigma), 'r-', lw=2, label=f'Normal Fit μ={mu:.2f}, σ={sigma:.2f}')\n",
    "plt.axvline(mu, color='black', linestyle='--', lw=1)\n",
    "plt.title(\"Docking Score Distribution with Normal Fit\")\n",
    "plt.xlabel(\"Docking Score\")\n",
    "plt.ylabel(\"Density\")\n",
    "plt.legend(frameon=False)\n",
    "plt.grid(alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(OUT_DIR, \"docking_distribution_fit.png\"), dpi=300)\n",
    "plt.show()\n",
    "\n",
    "# Robust Z-score\n",
    "def robust_z_score(x):\n",
    "    med = np.median(x)\n",
    "    mad = np.median(np.abs(x - med))\n",
    "    return (x - med) / (1.4826 * mad) if mad != 0 else np.zeros_like(x)\n",
    "\n",
    "out['binding_robust_z'] = robust_z_score(pd.to_numeric(out[DOCK_COL], errors='coerce'))\n",
    "out['is_outlier'] = out['binding_robust_z'].abs() > 2\n",
    "print(f\"=== Docking Outliers (|z|>2) === {out['is_outlier'].sum()}\")\n",
    "\n",
  
    "z_vals_clean = out.loc[~out['is_outlier'], 'binding_robust_z']\n",
    "\n",
    "plt.figure(figsize=(6,4))\n",
    "count, bins, _ = plt.hist(z_vals_clean, bins=30, density=True, alpha=0.6, edgecolor='k')\n",
    "plt.plot(x, norm.pdf(x, 0, 1), 'r-', lw=2, label='N(0,1)')\n",
    "plt.axvline(0, color='black', linestyle='--', lw=1)\n",
    "plt.title(\"Robust Z-score Distribution (cleaned Docking data)\")\n",
    "plt.xlabel(\"Robust Z-score\")\n",
    "plt.ylabel(\"Density\")\n",
    "plt.legend(frameon=False)\n",
    "plt.grid(alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(OUT_DIR, \"docking_zscore_clean_only.png\"), dpi=300)\n",
    "plt.show()\n",
    "\n",
  
    "X = out[TOX_COLS].fillna(out[TOX_COLS].median())\n",
    "\n",
    "\n",
    "\n",
   
    "clf = IsolationForest(contamination=0.02, random_state=42)\n",
    "outliers = clf.fit_predict(X)\n",
    "X_clean = X[outliers == 1]\n",
    "clean_idx = X_clean.index\n",
    "print(f\" {np.sum(outliers==-1)}\")\n",
    "\n",
   
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X_clean)\n",
    "pca = PCA(n_components=1)\n",
    "pc1 = pca.fit_transform(X_scaled).flatten()\n",
    "if np.corrcoef(pc1, X_scaled.mean(axis=1))[0,1] < 0:\n",
    "    pc1 = -pc1\n",
    "explained_var_ratio = pca.explained_variance_ratio_[0]\n",
    "print(f\" {explained_var_ratio:.2%}\")\n",
    "pc1_vals = pc1\n",
    "\n",
    "plt.figure(figsize=(6,4))\n",
    "sns.histplot(pc1_vals, kde=True, bins=40)\n",
    "plt.xlabel(\"PCA \")\n",
    "plt.ylabel(\"NUM\")\n",
    "plt.title(\"PC1 \")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
