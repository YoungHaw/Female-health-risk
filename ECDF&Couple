    "'''\n",
    "# ======================================================\n",
    "#               QQ 图 + KS 检验 + Multiplier α 分析\n",
    "# ======================================================\n",
    "import scipy.stats as stats\n",
    "import matplotlib.gridspec as gridspec\n",
    "USE_YEOJOHNSON = True\n",
    "MAD_Z_LIMIT = 3.0\n",
    "ISO_CONTAM = 0.02\n",
    "PCA_COMPONENTS = 1\n",
    "CLIP_PROB = (1e-6, 1-1e-6)\n",
    "\n",
    "def qq_plot(data, name):\n",
    "    plt.figure(figsize=(5,5))\n",
    "    stats.probplot(data, dist=\"norm\", plot=plt)\n",
    "    plt.title(f\"QQ Plot of {name}\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(os.path.join(OUT_DIR, f\"qq_{name}.png\"), dpi=300)\n",
    "    plt.close()\n",
    "\n",
    "qq_plot(p_B, \"p_B\")\n",
    "qq_plot(p_T, \"p_T\")\n",
    "\n",
    "# Kolmogorov–Smirnov test (uniformity)\n",
    "ks_pB = stats.kstest(p_B, \"uniform\")\n",
    "ks_pT = stats.kstest(p_T, \"uniform\")\n",
    "with open(os.path.join(OUT_DIR, \"ks_test_results.txt\"), \"w\") as f:\n",
    "    f.write(\"=== Kolmogorov–Smirnov Test ===\\n\")\n",
    "    f.write(f\"p_B vs Uniform: statistic={ks_pB.statistic:.4f}, p={ks_pB.pvalue:.4g}\\n\")\n",
    "    f.write(f\"p_T vs Uniform: statistic={ks_pT.statistic:.4f}, p={ks_pT.pvalue:.4g}\\n\")\n",
    "\n",
    "# Sensitivity Analysis over multiplier α\n",
    "alphas = np.linspace(0.5, 2.0, 10)\n",
    "rank_corr = []\n",
    "rank_ref = pd.Series(p_combined).rank(ascending=False)\n",
    "\n",
    "for a in alphas:\n",
    "    p_comb = p_T * (a * p_B)\n",
    "    p_comb = np.clip(p_comb, *CLIP_PROB)\n",
    "    rank = pd.Series(p_comb).rank(ascending=False)\n",
    "    corr = rank_ref.corr(rank, method=\"spearman\")\n",
    "    rank_corr.append(corr)\n",
    "\n",
    "plt.figure(figsize=(6,4))\n",
    "plt.plot(alphas, rank_corr, marker=\"o\")\n",
    "plt.xlabel(\"Multiplier α\")\n",
    "plt.ylabel(\"Spearman Rank Corr vs α=1\")\n",
    "plt.title(\"Sensitivity Analysis\")\n",
    "plt.grid(alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(OUT_DIR, \"sensitivity_alpha.png\"), dpi=300)\n",
    "plt.close()\n",
    "\n",
