    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import os\n",
    "from scipy.stats import norm, beta, gaussian_kde\n",
    "\n",
    "\n",
    "# ===========================================================\n",
    "# 1) 通用获取 Gaussian Copula correlation\n",
    "# ===========================================================\n",
    "def get_rho(copula):\n",
    "    \"\"\"\n",
    "    提取 Gaussian Copula 的相关系数 rho\n",
    "    完全兼容所有版本（不会再 KeyError）\n",
    "    \"\"\"\n",
    "\n",
    "    # ---------- 1) newest versions ----------\n",
    "    if hasattr(copula, \"params\"):\n",
    "        arr = np.asarray(copula.params)\n",
    "        return arr[0,1]\n",
    "\n",
    "\n",
    "    # ---------- 2) 如果 correlation 存在 ----------\n",
    "    if hasattr(copula, \"correlation\"):\n",
    "\n",
    "        corr = copula.correlation\n",
    "\n",
    "        # Case A： numpy / list\n",
    "        if isinstance(corr, (list, tuple, np.ndarray)):\n",
    "            return np.asarray(corr)[0,1]\n",
    "\n",
    "        # Case B： pandas DataFrame\n",
    "        if hasattr(corr, \"iloc\"):\n",
    "            try:\n",
    "                return corr.iloc[0,1]\n",
    "            except:\n",
    "                pass\n",
    "\n",
    "        # Case C： pandas DataFrame 按名称\n",
    "        if hasattr(corr, \"loc\"):\n",
    "            try:\n",
    "                i = corr.index[0]\n",
    "                j = corr.columns[1]\n",
    "                return corr.loc[i, j]\n",
    "            except:\n",
    "                pass\n",
    "\n",
    "\n",
    "    # ---------- 3) old versions ----------\n",
    "    if hasattr(copula, \"_learner\"):\n",
    "        learner = copula._learner\n",
    "        if hasattr(learner, \"correlation\"):\n",
    "            arr = np.asarray(learner.correlation)\n",
    "            return arr[0,1]\n",
    "\n",
    "\n",
    "    raise RuntimeError(\"无法从该版本 copulas 提取 correlation！\")\n",
    "\n",
    "\n",
    "\n",
    "# ===========================================================\n",
    "# 2) Copula + Beta 边际采样\n",
    "# ===========================================================\n",
    "def sample_from_gaussian_copula(n_samples, copula,\n",
    "                              a_B, b_B, a_T, b_T):\n",
    "\n",
    "    rho = get_rho(copula)\n",
    "\n",
    "    mean = [0,0]\n",
    "    cov  = [[1, rho],\n",
    "            [rho, 1]]\n",
    "\n",
    "    z = np.random.multivariate_normal(mean, cov, n_samples)\n",
    "\n",
    "    u = norm.cdf(z[:,0])\n",
    "    v = norm.cdf(z[:,1])\n",
    "\n",
    "    # 避免 beta.ppf 在 0 / 1 出现 inf\n",
    "    eps = 1e-10\n",
    "    u = np.clip(u, eps, 1-eps)\n",
    "    v = np.clip(v, eps, 1-eps)\n",
    "\n",
    "    b = beta.ppf(u, a_B, b_B)\n",
    "    t = beta.ppf(v, a_T, b_T)\n",
    "\n",
    "    return b, t\n",
    "\n",
    "\n",
    "\n",
    "# ===========================================================\n",
    "# 3) 拟合 Beta 边际\n",
    "# ===========================================================\n",
    "\n",
    "eps = 1e-6\n",
    "pB_clip = np.clip(p_B.values, eps, 1-eps)\n",
    "pT_clip = np.clip(p_T.values, eps, 1-eps)\n",
    "\n",
    "a_B, b_B, _, _ = beta.fit(pB_clip, floc=0, fscale=1)\n",
    "a_T, b_T, _, _ = beta.fit(pT_clip, floc=0, fscale=1)\n",
    "\n",
    "\n",
    "\n",
    "# ===========================================================\n",
    "# 4) Copula 联合采样\n",
    "# ===========================================================\n",
    "\n",
    "n_samples = 200000\n",
    "b_samp, t_samp = sample_from_gaussian_copula(\n",
    "    n_samples,\n",
    "    copula,\n",
    "    a_B, b_B,\n",
    "    a_T, b_T\n",
    ")\n",
    "\n",
    "\n",
    "\n",
    "# ===========================================================\n",
    "# 5) KDE 密度估计\n",
    "# ===========================================================\n",
    "\n",
    "xy = np.vstack([b_samp, t_samp])\n",
    "\n",
    "# KDE 要求全部 finite\n",
    "xy = xy[:, np.isfinite(xy).all(axis=0)]\n",
    "\n",
    "kde = gaussian_kde(xy)\n",
    "\n",
    "xmin, xmax = p_B.min(), p_B.max()\n",
    "ymin, ymax = p_T.min(), p_T.max()\n",
    "\n",
    "xx, yy = np.mgrid[xmin:xmax:200j,\n",
    "                  ymin:ymax:200j]\n",
    "\n",
    "positions = np.vstack([xx.ravel(), yy.ravel()])\n",
    "zz = np.reshape(kde(positions), xx.shape)\n",
    "\n",
    "\n",
