    "\n",
    "from scipy.stats import gaussian_kde\n",
    "\n",
    "final_idx = out.loc[\n",
    "    (~out['is_outlier']) &\n",
    "    (out.index.isin(X_clean.index))\n",
    "].index\n",
    "\n",

    "pc1_series = pd.Series(pc1_vals, index=X_clean.index)\n",
    "\n",

    "pc1_sub = pc1_series.loc[final_idx]\n",
    "\n",
    "# ======================================================\n",
    "# 3) Kernel CDF for p_T_score\n",
    "# ======================================================\n",
    "\n",
    "# 原始数据（全部 PC1），用于 KDE 拟合\n",
    "all_pc1 = pc1_series.values\n",
    "\n",
    "# KDE 密度估计\n",
    "kde_T = gaussian_kde(all_pc1)\n",
    "\n",
    "# 为 CDF 数值积分建立细网格\n",
    "xs_T = np.linspace(all_pc1.min(), all_pc1.max(), 4000)\n",
    "pdf_T = kde_T(xs_T)\n",
    "\n",
    "# 数值积分（梯形法）求 CDF\n",
    "dx_T = xs_T[1] - xs_T[0]\n",
    "cdf_T = np.cumsum((pdf_T[:-1] + pdf_T[1:]) / 2 * dx_T)\n",
    "cdf_T = np.concatenate([[0], cdf_T])   # 补齐前缀\n",
    "cdf_T = cdf_T / cdf_T[-1]              # 归一化到 0–1\n",
    "\n",
    "# 为 final_idx 上的数据插值得到 Kernel CDF 值\n",
    "p_T_score = np.interp(pc1_sub.values, xs_T, cdf_T)\n",
    "\n",
    "# 数值稳定\n",
    "eps = 1e-10\n",
    "p_T_score = np.clip(p_T_score, eps, 1 - eps)\n",
    "\n",
    "# 重新转成 Series\n",
    "p_T_score = pd.Series(p_T_score, index=final_idx)\n",
    "\n",
    "# ------------------------------------------------------\n",
    "# 1) 输入数据\n",
    "# ------------------------------------------------------\n",
    "z_B = z_vals_clean.loc[final_idx].values\n",
    "all_vals = z_vals_clean.values\n",
    "\n",
    "# ------------------------------------------------------\n",
    "# 2) KDE\n",
    "# ------------------------------------------------------\n",
    "kde = gaussian_kde(all_vals)\n",
    "\n",
    "# 网格数量越大越平滑\n",
    "xs = np.linspace(all_vals.min(), all_vals.max(), 4000)\n",
    "pdf = kde(xs)\n",
    "\n",
    "# ------------------------------------------------------\n",
    "# 3) 手写积分（梯形积分规则）\n",
    "# ------------------------------------------------------\n",
    "dx = xs[1] - xs[0]\n",
    "cdf = np.cumsum((pdf[:-1] + pdf[1:]) / 2 * dx)\n",
    "\n",
    "# 补齐长度（与 xs 对齐）\n",
    "cdf = np.concatenate([[0], cdf])\n",
    "\n",
    "# 归一化到 0～1\n",
    "cdf = cdf / cdf[-1]\n",
    "\n",
    "# ------------------------------------------------------\n",
    "# 4) 插值得到概率\n",
    "# ------------------------------------------------------\n",
    "p_B_score = np.interp(z_B, xs, cdf)\n",
    "\n",
    "# ------------------------------------------------------\n",
    "# 5) 防止进入 beta.ppf 出现 inf\n",
    "# ------------------------------------------------------\n",
    "eps = 1e-10\n",
    "p_B_score = np.clip(p_B_score, eps, 1-eps)\n",
    "\n",
    "# 转回 Series 保持风格一致\n",
    "p_B_score = pd.Series(p_B_score, index=final_idx)\n",
    "\n",
    "# uniform margins for Copula\n",
    "u = p_B_score\n",
    "v = p_T_score\n",
    "\n",
    "uv = pd.DataFrame({'u': u, 'v': v}, index=final_idx)\n",
    "copula = GaussianMultivariate(distribution='copulas.univariate.UniformUnivariate')\n",
    "copula.fit(uv)\n",
    "\n",
    "joint_cdf = copula.cumulative_distribution(uv)\n",
    "out.loc[final_idx, 'p_copula'] = joint_cdf\n",
    "def tail_prob(b_thresh, t_thresh):\n",
    "    # empirical CDF from raw B/T-score\n",
    "    FB = lambda x: (p_B_score <= x).mean()\n",
    "    FT = lambda y: (p_T_score <= y).mean()\n",
    "\n",
    "    u0 = FB(b_thresh)\n",
    "    v0 = FT(t_thresh)\n",
    "\n",
    "    Cuv = copula.cumulative_distribution(\n",
    "        pd.DataFrame({'u':[u0], 'v':[v0]})\n",
    "    )\n",
    "\n",
    "    Cuv = float(Cuv)   # <- 防止 scalar/index 失败\n",
    "\n",
    "    return 1 - u0 - v0 + Cuv\n",
    "b_grid = np.linspace(p_B_score.min(), p_B_score.max(), 50)\n",
    "t_grid = np.linspace(p_T_score.min(), p_T_score.max(), 50)\n",
    "\n",
    "tail_matrix = np.zeros((len(t_grid), len(b_grid)))\n",
    "\n",
    "for i, t_val in enumerate(t_grid):\n",
    "    for j, b_val in enumerate(b_grid):\n",
    "        tail_matrix[i, j] = tail_prob(b_val, t_val)\n",
    "\n",
    "eps = 1e-6\n",
    "vmin = max(tail_matrix.min(), eps)\n",
    "vmax = tail_matrix.max()\n",
    "if vmin >= vmax:\n",
    "    vmax = vmin + eps\n",
    "plt.figure(figsize=(7, 6))\n",
    "plt.imshow(\n",
    "    tail_matrix,\n",
    "    origin='lower',\n",
    "    extent=[b_grid.min(), b_grid.max(), t_grid.min(), t_grid.max()],\n",
    "    aspect='auto',\n",
    "    cmap='Reds',\n",
    "    norm=LogNorm(vmin=vmin, vmax=vmax)\n",
    ")\n",
    "plt.colorbar(label='P(B>b & T>t)')\n",
    "plt.xlabel('p_B threshold')\n",
    "plt.ylabel('p_T threshold')\n",
    "plt.title('Tail Probability Heatmap')\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(OUT_DIR, f\"{OUTPUT_PREFIX}_tail_prob_heatmap.png\"), dpi=300)\n",
    "plt.show()\n"
